# ========== SECRETS ==========
# Per-environment dart-define files contain Sentry DSN and any future secrets.
# The .example.json variant carries placeholder values and IS tracked.
/dart_defines/*.json
!/dart_defines/*.example.json

# Generic env files (defense in depth — none expected on the Flutter side today)
.env
.env.*
!.env.example

# Cryptographic / signing materials — never commit
*.keystore
*.jks
*.pem
*.p12
*.pfx
*.cer
*.mobileprovision

# Android signing config (also covered by android/.gitignore, repeated for safety)
android/key.properties
android/app/upload-keystore.jks
android/app/release-keystore.jks

# Firebase / Google service configs — contain project IDs and partial API keys.
# Treat as secret to avoid accidentally pushing staging-vs-prod variants.
ios/Runner/GoogleService-Info.plist
android/app/google-services.json

# Anything matching obvious secret naming
*secrets*
*.secret
*.secret.*

# ========== FLUTTER / DART BUILD ==========
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
flutter_*.png
linked_*.ds
unlinked.ds
unlinked_spec.ds

# Symbolication / obfuscation outputs
app.*.symbols
app.*.map.json

# Flutter Version Manager
.fvm/

# ========== iOS ==========
# Most iOS rules already live in ios/.gitignore (auto-generated by `flutter create`).
# Repeat the security-critical ones at root for defense-in-depth.
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework/
ios/Flutter/App.framework/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/ephemeral/
ios/Runner/GeneratedPluginRegistrant.*
**/xcuserdata/
**/DerivedData/
**/.symlinks/
*.xcuserstate

# ========== ANDROID ==========
# Most Android rules live in android/.gitignore. Repeat critical ones here.
/android/.gradle/
/android/app/debug
/android/app/profile
/android/app/release
/android/captures/
/android/local.properties
/android/.cxx/
**/GeneratedPluginRegistrant.java

# ========== IDE ==========
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code — ignored entirely. We use --dart-define-from-file for secrets,
# not launch.json. If you need shared launch config later, switch to a
# committed .vscode/launch.json that references a gitignored env file.
.vscode/

# Eclipse
.classpath
.project
.settings/

# Misc editor backups
*.swp
*.swo
*~

# ========== OS ==========
**/.DS_Store
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ========== TEST / COVERAGE ==========
**/coverage/
*.lcov
test/.test_coverage.dart

# ========== MISC ==========
*.class
*.log
*.pyc
.atom/
.build/
.buildlog/
.history/
.svn/
.swiftpm/
migrate_working_dir/
